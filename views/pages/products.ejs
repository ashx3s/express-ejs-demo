<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('../partials/head', { title: title }) %>
  </head>
  <body>
    <%- include('../partials/header') %>

    <main>
      <h1><%= title %></h1>
      <ul>
        <% products.forEach(product => { %>
          <li>
            <strong><%= product.name %></strong> - $<%= product.price %>
          </li>
        <% }); %>
      </ul>
    </main>

    <%- include('../partials/footer') %>
  </body>
</html>
